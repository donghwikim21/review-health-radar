# ---- Required ----

# GitHub personal access token with READ-ONLY scopes (public_repo / repo:read is plenty).
# Create one at https://github.com/settings/tokens — a fine-grained token with
# "Public repositories (read-only)" works and is the least-privilege choice.
GITHUB_TOKEN=

# Anthropic API key for the narrative endpoint. https://console.anthropic.com/
# Only required for the /narrative endpoint and `npm run eval -- --live`.
ANTHROPIC_API_KEY=

# ---- Optional (sensible defaults shown) ----

# HTTP port the service listens on.
PORT=3000

# Claude model used for narrative synthesis. claude-haiku-4-5-20251001 is the
# cheaper option; claude-sonnet-4-6 gives stronger causal reasoning.
INSIGHT_MODEL=claude-sonnet-4-6

# How long (seconds) cached upstream GitHub data is considered fresh.
CACHE_TTL_SECONDS=3600

# Run the adversarial "skeptic" verification pass on each narrative (a second LLM
# call that tries to refute the hypothesis and scales the confidence). Set to
# false to skip it (one fewer model call per narrative).
VERIFY_NARRATIVE=true

# SQLite database file location.
DATABASE_PATH=./data/review-health.db

# Largest analysis window allowed, in days (guards against runaway fetches).
MAX_WINDOW_DAYS=180

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
